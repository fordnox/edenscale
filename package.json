{
  "name": "edenscale",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@11.15.1",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "generate-client": "turbo run generate-client",
    "dev:manager": "turbo run dev --filter=manager",
    "dev:investor": "turbo run dev --filter=investor",
    "build:gateway": "turbo run build --filter=gateway"
  },
  "devDependencies": {
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.7.0",
    "turbo": "^2.10.5",
    "typescript-eslint": "^8.65.0"
  }
}
