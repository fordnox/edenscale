{
  "name": "edenscale",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@11.15.1",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "generate-client": "turbo run generate-client",
    "dev:manager": "turbo run dev --filter=manager",
    "dev:investor": "turbo run dev --filter=investor",
    "build:gateway": "turbo run build --filter=gateway"
  },
  "devDependencies": {
    "turbo": "^2.10.5"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "19.2.17",
      "@types/react-dom": "19.2.3"
    }
  }
}
