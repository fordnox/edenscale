{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "newtaven-gateway",
  "main": "./worker/index.ts",
  "compatibility_date": "2026-05-07",
  "workers_dev": true,
  "assets": {
    "directory": "./dist",
    "not_found_handling": "404-page",
    "binding": "ASSETS",
    "run_worker_first": ["/manager/*", "/investor/*", "/app/*"]
  },
  "observability": {
    "enabled": true
  },
  "routes": [
    {
      "pattern": "newtaven.com",
      "custom_domain": true
    }
  ]
}
