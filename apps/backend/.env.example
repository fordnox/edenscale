APP_DOMAIN=example.com
APP_DOMAIN_URL=http://localhost:3000
APP_DATA_PATH=var/lib/app
APP_DATABASE_DSN=sqlite:///var/lib/app/database.db
CORS_ALLOW_ORIGINS=["http://localhost:3000"]
REDIS_URL=redis://localhost:6379
HANKO_API_URL=https://your-tenant-id.hanko.io
HANKO_API_KEY=
# Superadmins are defined here, not in the database: a signed-in user whose
# Hanko-verified email matches is a superadmin. Comma-separate for several.
SUPERADMIN_EMAIL=

# Document storage: "local" writes to APP_DATA_PATH/dev_storage; "s3" presigns
# direct-to-bucket uploads against any S3-compatible endpoint (R2/MinIO/AWS)
# using the S3_* settings below. The bucket needs CORS for browser PUT/GET.
STORAGE_BACKEND=local
S3_ENDPOINT_URL=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=
S3_REGION=auto
S3_PUBLIC_URL=
S3_PREFIX=