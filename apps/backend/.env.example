# --- Core app settings ---------------------------------------------------
# REQUIRED
APP_DOMAIN=example.com
# OPTIONAL — unused by any app code today (reserved). Default: false
DEBUG=false
# OPTIONAL — feature disabled if unset: interactive API docs (/docs, /redoc)
# and the raw /openapi.json HTTP endpoint return 404. `make openapi` does NOT
# need this set — it calls the FastAPI schema function directly, not the
# HTTP endpoint. Default: false
GENERATE_OPENAPI_DOCS=false
# OPTIONAL — default /tmp. Only read when STORAGE_BACKEND=local, as the base
# directory for dev document storage (APP_DATA_PATH/dev_storage).
APP_DATA_PATH=var/lib/app
# REQUIRED
APP_DATABASE_DSN=sqlite:///var/lib/app/database.db
# REQUIRED
CORS_ALLOW_ORIGINS=["http://localhost:3000"]
# REQUIRED — background jobs (arq worker/queue) depend on Redis.
REDIS_URL=redis://localhost:6379

# --- Auth (Hanko) ----------------------------------------------------------
# REQUIRED — without these, JWT validation cannot reach Hanko's JWKS
# endpoint and every authenticated request fails.
HANKO_API_URL=https://your-tenant-id.hanko.io
HANKO_API_KEY=
# OPTIONAL — default "localhost" works for local dev. Set to the real
# audience value used by your Hanko tenant in staging/production.
HANKO_AUDIENCE=localhost
# Superadmins are defined here, not in the database: a signed-in user whose
# Hanko-verified email matches is a superadmin. Comma-separate for several.
# OPTIONAL — empty means no superadmins.
SUPERADMIN_EMAIL=

# --- Notifications / email --------------------------------------------------
# OPTIONAL — feature disabled if unset: without RESEND_API_KEY the email
# channel no-ops (returns a failure and nothing leaves the box). In-app
# notification rows and logs are still written either way — no error is
# raised, so this fails silently.
RESEND_API_KEY=
# OPTIONAL — has a working default; override per environment if needed.
NOTIFICATION_FROM_EMAIL=notifications@updates.newtaven.com

# --- Inbound email -> document ingestion -----------------------------------
# OPTIONAL — feature disabled if unset: the /email-ingest/documents endpoint
# (used by the Cloudflare email-ingest Worker) returns 404 until a token is
# set here, matched against the Worker's `X-Email-Ingest-Token` header.
EMAIL_INGEST_TOKEN=

# --- AI letter drafting (OpenRouter) ----------------------------------------
# OPTIONAL — feature disabled if unset: without OPENROUTER_API_KEY the
# documents library's "Draft letter" action is inert and its endpoint
# returns 404. No error surfaces elsewhere — this fails silently.
OPENROUTER_API_KEY=
# OPTIONAL — has a working default; any OpenRouter model slug.
OPENROUTER_MODEL=anthropic/claude-opus-4.8
# OPTIONAL — has a working default.
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# --- Document storage --------------------------------------------------------
# Document storage: "local" writes to APP_DATA_PATH/dev_storage; "s3" presigns
# direct-to-bucket uploads against any S3-compatible endpoint (R2/MinIO/AWS)
# using the S3_* settings below. The bucket needs CORS for browser PUT/GET.
# OPTIONAL — default "local".
STORAGE_BACKEND=local
# OPTIONAL — default "dev-storage". Only used when STORAGE_BACKEND=local;
# protects the dev upload endpoint. Must match VITE_DEV_STORAGE_TOKEN on the
# frontend for local uploads to work.
DEV_STORAGE_TOKEN=dev-storage
# OPTIONAL — only read when STORAGE_BACKEND=s3.
S3_ENDPOINT_URL=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=
S3_REGION=auto
S3_PUBLIC_URL=
S3_PREFIX=
