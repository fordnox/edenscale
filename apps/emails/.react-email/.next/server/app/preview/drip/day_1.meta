{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/preview/layout,_N_T_/preview/[...slug]/layout,_N_T_/preview/[...slug]/page,_N_T_/preview/drip/day_1"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/preview/$c$slug/__PAGE__",
    "/preview/$c$slug",
    "/preview",
    "/_index",
    "/_head"
  ]
}