3:T422c,<!DOCTYPE html PUBLIC "-//W3C//DTD XHTML 1.0 Transitional//EN" "http://www.w3.org/TR/xhtml1/DTD/xhtml1-transitional.dtd">
<html dir="ltr" lang="en">
  <head>
    <meta content="text/html; charset=UTF-8" http-equiv="Content-Type" />
    <meta name="x-apple-disable-message-reformatting" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,500;0,600;1,500&amp;family=Inter:wght@400;500;600&amp;display=swap" />
  </head>
  <body style="background-color:#fbf9f4">
    <!--$--><!--html--><!--head-->
    <div
      style="display:none;overflow:hidden;line-height:1px;opacity:0;max-height:0;max-width:0"
      data-skip-in-text="true">
      The latest report per fund, and the history behind it
      <div>
         ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿
      </div>
    </div>
    <!--body-->
    <table
      border="0"
      width="100%"
      cellpadding="0"
      cellspacing="0"
      role="presentation"
      align="center">
      <tbody>
        <tr>
          <td
            style='background-color:#fbf9f4;font-family:Inter, "Inter Tight", -apple-system, Helvetica, Arial, sans-serif;margin:0;padding:32px 0'>
            <table
              align="center"
              width="100%"
              border="0"
              cellpadding="0"
              cellspacing="0"
              role="presentation"
              style="max-width:100%;width:560px;margin:0 auto;background-color:#ffffff;border:1px solid rgba(26,26,24,0.10);border-top:3px solid #1f3d2e">
              <tbody>
                <tr style="width:100%">
                  <td>
                    <table
                      align="center"
                      width="100%"
                      border="0"
                      cellpadding="0"
                      cellspacing="0"
                      role="presentation"
                      style="padding:22px 32px 0;display:flex;justify-content:space-between;align-items:baseline">
                      <tbody>
                        <tr>
                          <td>
                            <p
                              style='font-size:22px;line-height:24px;font-family:"Cormorant Garamond", "Times New Roman", Times, serif;font-weight:600;letter-spacing:-0.01em;color:#1f3d2e;margin:0;margin-top:0;margin-bottom:0;margin-left:0;margin-right:0'>
                              {{{organization_name}}}
                            </p>
                            <p
                              style='font-size:10px;line-height:24px;font-family:Inter, "Inter Tight", -apple-system, Helvetica, Arial, sans-serif;font-weight:600;letter-spacing:0.18em;text-transform:uppercase;color:#8a6a3f;margin:0;margin-top:0;margin-bottom:0;margin-left:0;margin-right:0'>
                              Reports · 5 of 7
                            </p>
                          </td>
                        </tr>
                      </tbody>
                    </table>
                    <table
                      align="center"
                      width="100%"
                      border="0"
                      cellpadding="0"
                      cellspacing="0"
                      role="presentation"
                      style="padding:8px 32px 32px">
                      <tbody>
                        <tr>
                          <td>
                            <p
                              style='font-size:30px;line-height:1.05;font-family:"Cormorant Garamond", "Times New Roman", Times, serif;font-weight:600;letter-spacing:-0.015em;color:#1a1a18;margin:14px 0 18px;margin-top:14px;margin-right:0;margin-bottom:18px;margin-left:0'>
                              Your reports.
                            </p>
                            <p
                              style='font-size:15px;line-height:1.55;font-family:Inter, "Inter Tight", -apple-system, Helvetica, Arial, sans-serif;color:#3a3a36;margin:0 0 14px;margin-top:0;margin-right:0;margin-bottom:14px;margin-left:0'>
                              {{{recipient_name}}}<!-- -->
                              — reporting is the part of the relationship you
                              will return to most, so it has a page of its own
                              rather than being buried in a folder tree.
                            </p>
                            <table
                              align="center"
                              width="100%"
                              border="0"
                              cellpadding="0"
                              cellspacing="0"
                              role="presentation"
                              style="border:1px solid rgba(26,26,24,0.10);padding:18px;margin:8px 0 22px;background-color:#fbf9f4">
                              <tbody>
                                <tr>
                                  <td>
                                    <p
                                      style='font-size:10px;line-height:24px;font-family:Inter, "Inter Tight", -apple-system, Helvetica, Arial, sans-serif;font-weight:600;letter-spacing:0.18em;text-transform:uppercase;color:#8a6a3f;margin:0;margin-bottom:14px;margin-top:0;margin-left:0;margin-right:0'>
                                      How it is organised
                                    </p>
                                    <div>
                                      <p
                                        style='font-size:14px;line-height:24px;font-family:Inter, "Inter Tight", -apple-system, Helvetica, Arial, sans-serif;font-weight:600;color:#1a1a18;margin:0;margin-top:0;margin-bottom:0;margin-left:0;margin-right:0'>
                                        Grouped by fund
                                      </p>
                                      <p
                                        style='font-size:14px;line-height:1.5;font-family:Inter, "Inter Tight", -apple-system, Helvetica, Arial, sans-serif;color:#6f6e68;margin:3px 0 0;margin-top:3px;margin-right:0;margin-bottom:0;margin-left:0'>
                                        Each fund you hold gets its own section.
                                        Reports that apply to the whole firm are
                                        grouped as Firm-wide.
                                      </p>
                                    </div>
                                    <div>
                                      <hr
                                        style="width:100%;border:none;border-top:1px solid #eaeaea;border-color:rgba(26,26,24,0.10);border-top-width:1px;margin:14px 0" />
                                      <p
                                        style='font-size:14px;line-height:24px;font-family:Inter, "Inter Tight", -apple-system, Helvetica, Arial, sans-serif;font-weight:600;color:#1a1a18;margin:0;margin-top:0;margin-bottom:0;margin-left:0;margin-right:0'>
                                        The latest is surfaced first
                                      </p>
                                      <p
                                        style='font-size:14px;line-height:1.5;font-family:Inter, "Inter Tight", -apple-system, Helvetica, Arial, sans-serif;color:#6f6e68;margin:3px 0 0;margin-top:3px;margin-right:0;margin-bottom:0;margin-left:0'>
                                        The most recent report for each fund
                                        sits at the top with its publication
                                        date, ready to view or download.
                                      </p>
                                    </div>
                                    <div>
                                      <hr
                                        style="width:100%;border:none;border-top:1px solid #eaeaea;border-color:rgba(26,26,24,0.10);border-top-width:1px;margin:14px 0" />
                                      <p
                                        style='font-size:14px;line-height:24px;font-family:Inter, "Inter Tight", -apple-system, Helvetica, Arial, sans-serif;font-weight:600;color:#1a1a18;margin:0;margin-top:0;margin-bottom:0;margin-left:0;margin-right:0'>
                                        The history sits beneath it
                                      </p>
                                      <p
                                        style='font-size:14px;line-height:1.5;font-family:Inter, "Inter Tight", -apple-system, Helvetica, Arial, sans-serif;color:#6f6e68;margin:3px 0 0;margin-top:3px;margin-right:0;margin-bottom:0;margin-left:0'>
                                        Every earlier report stays available,
                                        newest first. Nothing is retired when a
                                        new quarter is published.
                                      </p>
                                    </div>
                                  </td>
                                </tr>
                              </tbody>
                            </table>
                            <table
                              align="center"
                              width="100%"
                              border="0"
                              cellpadding="0"
                              cellspacing="0"
                              role="presentation"
                              style="border-left:2px solid #b8915c;padding:2px 0 2px 14px;margin:0 0 22px">
                              <tbody>
                                <tr>
                                  <td>
                                    <p
                                      style='font-size:13px;line-height:1.5;font-family:Inter, "Inter Tight", -apple-system, Helvetica, Arial, sans-serif;color:#6f6e68;margin:0;margin-top:0;margin-bottom:0;margin-left:0;margin-right:0'>
                                      Reports are also filed in Documents
                                      alongside everything else shared with you.
                                      This page is the reading view; Documents
                                      is the record.
                                    </p>
                                  </td>
                                </tr>
                              </tbody>
                            </table>
                            <table
                              align="center"
                              width="100%"
                              border="0"
                              cellpadding="0"
                              cellspacing="0"
                              role="presentation"
                              style="text-align:center;margin:18px 0 4px">
                              <tbody>
                                <tr>
                                  <td>
                                    <a
                                      href="{{{app_url}}}"
                                      style='line-height:100%;text-decoration:none;display:inline-block;max-width:100%;mso-padding-alt:0px;background-color:#1f3d2e;color:#ffffff;padding:12px 22px;border-radius:2px;font-family:Inter, "Inter Tight", -apple-system, Helvetica, Arial, sans-serif;font-weight:600;font-size:14px;padding-top:12px;padding-right:22px;padding-bottom:12px;padding-left:22px'
                                      target="_blank"
                                      ><span
                                        ><!--[if mso]><i style="mso-font-width:366.66666666666663%;mso-text-raise:18" hidden>&#8202;&#8202;&#8202;</i><![endif]--></span
                                      ><span
                                        style="max-width:100%;display:inline-block;line-height:120%;mso-padding-alt:0px;mso-text-raise:9px"
                                        >Read your latest report</span
                                      ><span
                                        ><!--[if mso]><i style="mso-font-width:366.66666666666663%" hidden>&#8202;&#8202;&#8202;&#8203;</i><![endif]--></span
                                      ></a
                                    >
                                  </td>
                                </tr>
                              </tbody>
                            </table>
                            <hr
                              style="width:100%;border:none;border-top:1px solid #eaeaea;border-color:rgba(26,26,24,0.10);margin:28px 0 14px" />
                            <p
                              style='font-size:10px;line-height:24px;font-family:Inter, "Inter Tight", -apple-system, Helvetica, Arial, sans-serif;font-weight:600;letter-spacing:0.18em;text-transform:uppercase;color:#8a6a3f;margin:0;margin-top:0;margin-bottom:0;margin-left:0;margin-right:0'>
                              Day 5 of 7
                            </p>
                            <p
                              style='font-size:13px;line-height:24px;font-family:Inter, "Inter Tight", -apple-system, Helvetica, Arial, sans-serif;color:#6f6e68;margin:6px 0 0;margin-top:6px;margin-right:0;margin-bottom:0;margin-left:0'>
                              Next: the data room.
                            </p>
                          </td>
                        </tr>
                      </tbody>
                    </table>
                    <hr
                      style="width:100%;border:none;border-top:1px solid #eaeaea;border-color:rgba(26,26,24,0.10);margin:0" />
                    <table
                      align="center"
                      width="100%"
                      border="0"
                      cellpadding="0"
                      cellspacing="0"
                      role="presentation"
                      style="padding:20px 32px;background-color:#1f3d2e">
                      <tbody>
                        <tr>
                          <td>
                            <p
                              style='font-size:12px;line-height:24px;font-family:"JetBrains Mono", ui-monospace, Menlo, monospace;color:rgba(251,249,244,0.72);margin:0;margin-top:0;margin-bottom:0;margin-left:0;margin-right:0'>
                              {{{organization_name}}}
                            </p>
                            <p
                              style='font-size:12px;line-height:24px;font-family:"JetBrains Mono", ui-monospace, Menlo, monospace;color:rgba(251,249,244,0.5);margin:0;margin-top:6px;margin-bottom:0;margin-left:0;margin-right:0'>
                              {{{organization_website}}} ·
                              <!-- -->Delivered by NewTaven
                            </p>
                          </td>
                        </tr>
                      </tbody>
                    </table>
                  </td>
                </tr>
              </tbody>
            </table>
          </td>
        </tr>
      </tbody>
    </table>
    <!--/$-->
  </body>
</html>
