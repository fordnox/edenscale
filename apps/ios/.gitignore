# Dependencies
node_modules/

# Built web bundle — regenerated by scripts/prepare.sh on every build
www/

# Signed archives / exported IPAs
build/

# Local build-time config & secrets (Team ID, API URLs)
.env

# Native iOS project — generated by `make ios` (cap add ios), which needs Xcode
# + CocoaPods and can't run in CI-only environments. Once you customize native
# config (app icons, entitlements, Info.plist, version bumps) you'll want it
# tracked: delete the line below and commit the ios/ folder. See README ▸ Native
# project: generated vs. committed.
ios/
