# ---------------------------------------------------------------------------
# Build-time configuration for the iOS bundle. Copy to `.env` and fill in.
#   cp apps/ios/.env.example apps/ios/.env
# `.env` is git-ignored. These values are baked into the app at build time.
# ---------------------------------------------------------------------------

# --- Web app configuration (read by the investor SPA / Vite) ---------------
# Production API base URL the app talks to. MUST be a real https host reachable
# from a device — never localhost, or the app works only in the simulator.
VITE_API_URL=https://api.newtaven.com

# Hanko auth API URL (from your Hanko project).
VITE_HANKO_API_URL=https://your-project.hanko.io

VITE_APP_TITLE=NewTaven
VITE_APP_URL=https://newtaven.com

# --- Native identifiers (read by capacitor.config.ts / archive.sh) ---------
# Reverse-DNS bundle identifier. Register this in the Apple Developer portal.
IOS_BUNDLE_ID=com.newtaven.investor
IOS_APP_NAME=NewTaven Investor

# Your Apple Developer Team ID (Developer portal ▸ Membership). Required for
# `make ios-archive`. Automatic signing uses the certificates in your Xcode
# account for this team.
APPLE_TEAM_ID=

# --- Hosted mode (optional) ------------------------------------------------
# Leave empty to ship the bundled web assets (offline shell). Set to your live
# investor origin to load it directly instead — usually needed for Hanko
# passkey + cookie auth. See README ▸ Authentication.
# CAP_SERVER_URL=https://newtaven.com/investor
