# REQUIRED — the backend API base URL. Without it the app falls back to
# http://localhost:8000, which is right for local dev but a hard blocker in
# any other environment.
VITE_API_URL=http://localhost:8000

VITE_APP_TITLE="NewTaven"
# OPTIONAL — support/contact address shown in the UI. Has a code fallback if unset.
VITE_APP_EMAIL=support@example.com
# OPTIONAL — this app's own public URL, used for links back to itself. Has a
# code fallback ("https://example.com") if unset.
VITE_APP_URL=http://localhost:3002

# REQUIRED — without it, Hanko auth cannot initialize and sign-in is broken.
VITE_HANKO_API_URL=https://your-tenant-id.hanko.io
# OPTIONAL — feature disabled if unset: Google sign-in is unavailable.
# Declared in vite-env.d.ts but not yet wired to any component.
VITE_GOOGLE_CLIENT_ID=
# OPTIONAL — must match the backend's DEV_STORAGE_TOKEN. Only relevant when
# the backend's STORAGE_BACKEND=local; has a matching default of "dev-storage".
VITE_DEV_STORAGE_TOKEN=dev-storage

# OPTIONAL — declared for future use, not currently read by any component.
VITE_APP_SLOGAN=
# OPTIONAL — declared for future use, not currently read by any component.
VITE_GITHUB_URL=
