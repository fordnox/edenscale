---
import Mark from "./Mark.astro";
import CtaButton from "./CtaButton.astro";
---

<nav id="nt-nav" class="nt-nav" aria-label="Primary">
  <div class="nt-nav-inner">
    <a href="#top" class="nt-nav-brand">
      <Mark size={20} />
      <span>NewTaven</span>
    </a>
    <div class="nt-nav-links">
      <a href="#problem" class="nt-link nt-mono">Problem</a>
      <a href="#how" class="nt-link nt-mono">How it works</a>
      <a href="#cadence" class="nt-link nt-mono">Cadence</a>
      <a href="#features" class="nt-link nt-mono">Features</a>
      <a href="#pricing" class="nt-link nt-mono">Pricing</a>
      <CtaButton class="nt-nav-cta" />
    </div>
  </div>
</nav>

<style>
  .nt-nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 50;
    opacity: 0;
    /* visibility keeps the hidden nav out of the tab order; the delayed
       visibility transition lets the fade-out finish before it leaves. */
    visibility: hidden;
    pointer-events: none;
    transition:
      opacity var(--motion-base) var(--ease-standard),
      visibility 0s linear var(--motion-base);
    background: var(--parchment-50);
    border-bottom: 1px solid var(--border-hairline);
    box-shadow: var(--shadow-xs);
  }
  .nt-nav.is-visible {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
    transition: opacity var(--motion-base) var(--ease-standard);
  }
  @media (prefers-reduced-motion: reduce) {
    .nt-nav,
    .nt-nav.is-visible {
      transition: none;
    }
  }
  .nt-nav-inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 var(--gut);
    height: 60px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
  }
  .nt-nav-brand {
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 16px;
    letter-spacing: -0.01em;
    color: var(--fg-primary);
  }
  .nt-nav-links {
    display: flex;
    align-items: center;
    gap: 28px;
  }
  .nt-nav-links a.nt-link {
    font-size: 11.5px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--fg-secondary);
  }
  @media (max-width: 760px) {
    .nt-nav-links a.nt-link {
      display: none;
    }
  }
</style>

<script>
  const nav = document.getElementById("nt-nav");
  if (nav) {
    const onScroll = () => {
      nav.classList.toggle("is-visible", window.scrollY > 600);
    };
    window.addEventListener("scroll", onScroll, { passive: true });
    onScroll();
  }
</script>
