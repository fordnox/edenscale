---
/* Generative paper-grain background, ported from the design comp
   (apps/design/NewTaven Homepage.dc.html). `page` renders a fixed,
   viewport-sized field in ink; `dark` renders an absolute parchment field
   inside a dark container; `card` renders an absolute ink field inside a
   light container. Absolute variants need a position: relative parent with
   its content above z-index 0. `pattern` mirrors the comp's noisePattern
   prop: "lines" (flow-field strokes) or "dots" (grain specks). */
interface Props {
  kind?: "page" | "dark" | "card";
  pattern?: "lines" | "dots";
}
const { kind = "dark", pattern = "lines" } = Astro.props;
const isPage = kind === "page";
const tone = kind === "dark" ? "parchment" : "ink";
const base = kind === "dark" ? "0.10" : kind === "card" ? "0.06" : "0.05";
---

<svg
  data-noise={kind}
  data-tone={tone}
  data-base={base}
  data-pattern={pattern}
  aria-hidden="true"
  class:list={["grain-field", isPage ? "grain-field--page" : "grain-field--abs"]}
></svg>

<style>
  .grain-field {
    z-index: 0;
    pointer-events: none;
    /* The controller sets the final opacity after it fills the field. */
    opacity: 0;
  }
  .grain-field--page {
    position: fixed;
    inset: 0;
    width: 100%;
    height: 100%;
  }
  .grain-field--abs {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }
</style>

<script>
  import { renderNoiseField, type NoiseMode } from "../lib/noise-field";

  /* The design comp exposed noiseIntensity as an editor prop; this is the
     shipped default. The pattern comes per-instance via data-pattern. */
  const INTENSITY = 1;

  interface Mark {
    el: SVGElement;
    cx: number;
    cy: number;
    base: number;
    type: "line" | "dot";
    active: boolean;
  }
  interface Field {
    svg: SVGSVGElement;
    marks: Mark[];
  }

  let fields: Field[] = [];

  function build() {
    const mult = 0.35 + INTENSITY * 1.3;
    fields = [];
    document.querySelectorAll<SVGSVGElement>("svg[data-noise]").forEach((svg) => {
      const kind = svg.getAttribute("data-noise");
      const rect = svg.getBoundingClientRect();
      const w = Math.ceil(rect.width) || window.innerWidth;
      const h = Math.ceil(rect.height) || window.innerHeight;
      if (w < 2 || h < 2) return;
      const color = svg.getAttribute("data-tone") === "parchment" ? "#FBF9F4" : "#1A1A18";
      const base = parseFloat(svg.getAttribute("data-base") || "") || 0.05;
      const pattern: NoiseMode = svg.getAttribute("data-pattern") === "dots" ? "dots" : "lines";
      const res = kind === "page" ? 34 : 26;
      svg.setAttribute("viewBox", `0 0 ${w} ${h}`);
      svg.setAttribute("preserveAspectRatio", "none");
      svg.innerHTML = renderNoiseField({ width: w, height: h, res, mode: pattern, color });
      svg.style.opacity = String(Math.min(0.24, base * mult));

      const marks: Mark[] = [];
      if (pattern === "dots") {
        svg.querySelectorAll("circle").forEach((el) => {
          marks.push({
            el,
            cx: +(el.getAttribute("cx") || 0),
            cy: +(el.getAttribute("cy") || 0),
            base: +(el.getAttribute("r") || 0),
            type: "dot",
            active: false,
          });
        });
      } else {
        svg.querySelectorAll("line").forEach((el) => {
          const m = (el.getAttribute("transform") || "").match(
            /rotate\(([-0-9.]+) ([-0-9.]+) ([-0-9.]+)\)/,
          );
          if (m) marks.push({ el, base: +m[1], cx: +m[2], cy: +m[3], type: "line", active: false });
        });
      }
      fields.push({ svg, marks });
    });
  }

  /* Mouse-reactive flow field: marks inside a 190px radius ease away from
     the cursor; lines also swing tangent to it, dots swell. */
  function startReactive() {
    let tx = window.innerWidth / 2;
    let ty = window.innerHeight / 2;
    let cx = tx;
    let cy = ty;
    let hasMouse = false;
    window.addEventListener(
      "mousemove",
      (e) => {
        tx = e.clientX;
        ty = e.clientY;
        hasMouse = true;
      },
      { passive: true },
    );
    window.addEventListener(
      "mouseout",
      (e) => {
        if (!e.relatedTarget) hasMouse = false;
      },
      { passive: true },
    );

    const R = 190;
    const smooth = (t: number) => t * t * (3 - 2 * t);
    const tick = () => {
      requestAnimationFrame(tick);
      cx += (tx - cx) * 0.16;
      cy += (ty - cy) * 0.16;
      for (const field of fields) {
        const rect = field.svg.getBoundingClientRect();
        if (rect.width < 2) continue;
        const mx = cx - rect.left;
        const my = cy - rect.top;
        for (const m of field.marks) {
          const dx = mx - m.cx;
          const dy = my - m.cy;
          const d2 = dx * dx + dy * dy;
          if (hasMouse && d2 < R * R) {
            const d = Math.sqrt(d2) || 0.001;
            const inf = smooth(1 - d / R);
            const ox = (-dx / d) * inf * 8;
            const oy = (-dy / d) * inf * 8;
            if (m.type === "line") {
              const tan = (Math.atan2(dy, dx) * 180) / Math.PI + 90;
              const diff = ((tan - m.base + 540) % 360) - 180;
              const a = m.base + diff * inf;
              m.el.setAttribute(
                "transform",
                `translate(${ox.toFixed(1)} ${oy.toFixed(1)}) rotate(${a.toFixed(1)} ${m.cx} ${m.cy})`,
              );
            } else {
              m.el.setAttribute("transform", `translate(${ox.toFixed(1)} ${oy.toFixed(1)})`);
              m.el.setAttribute("r", (m.base * (1 + inf * 1.6)).toFixed(2));
            }
            m.active = true;
          } else if (m.active) {
            if (m.type === "line") {
              m.el.setAttribute("transform", `rotate(${m.base} ${m.cx} ${m.cy})`);
            } else {
              m.el.removeAttribute("transform");
              m.el.setAttribute("r", String(m.base));
            }
            m.active = false;
          }
        }
      }
    };
    requestAnimationFrame(tick);
  }

  build();
  window.addEventListener("load", build);

  let resizeTimer: ReturnType<typeof setTimeout>;
  window.addEventListener("resize", () => {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(build, 200);
  });

  const finePointer = window.matchMedia("(hover: hover) and (pointer: fine)").matches;
  const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
  if (finePointer && !reducedMotion) startReactive();
</script>
