<script
    define:vars={{
        presets,
        defaultOutput,
        vaultDocs,
        vaultSeed,
        FLOW_ROWS,
        FLOW_ROW_H,
        FLOW_ENTER_Y,
        FLOW_EXIT_Y,
    }}
>
    // Scroll reveals — opacity 0 -> 1 + translateY, once
    const revealObs = new IntersectionObserver(
        (entries) => {
            entries.forEach((entry) => {
                if (entry.isIntersecting) {
                    entry.target.classList.add("is-visible");
                    revealObs.unobserve(entry.target);
                }
            });
        },
        { threshold: 0.15 },
    );
    document
        .querySelectorAll("[data-reveal]")
        .forEach((el) => revealObs.observe(el));

    const reducedMotion = window.matchMedia(
        "(prefers-reduced-motion: reduce)",
    ).matches;

    // Hero flow — the document queue advances one slot at a time: a new document
    // slides in at the top, the stack shifts down, the oldest drops into the
    // backlog pill, and the vault totals tick up.
    const flow = document.querySelector("[data-flow]");
    if (flow) {
        const list = flow.querySelector("[data-flow-list]");
        const docsEl = flow.querySelector("[data-vault-docs]");
        const sizeEl = flow.querySelector("[data-vault-size]");
        const moreEl = flow.querySelector("[data-more-count]");
        const rows = Array.from(list.querySelectorAll(".flow-row"));
        const template = rows[0].cloneNode(true);
        const slotY = (i) => FLOW_ROWS[i] - FLOW_ROW_H / 2;

        let next = 3;
        let docs = vaultSeed.docs;
        let size = vaultSeed.size;
        let more = vaultSeed.more;

        const nearTiles = Array.from(flow.querySelectorAll(".flow-tile[data-near]"));

        const fill = (el, doc) => {
            el.querySelector(".flow-page-type").textContent = doc.type;
            el.querySelector(".flow-row-name").textContent = doc.name;
            el.querySelector(".flow-row-meta").textContent = doc.from;
        };

        const advance = () => {
            const leaving = rows.pop();
            leaving.style.setProperty("--y", `${FLOW_EXIT_Y}px`);
            leaving.style.opacity = "0";
            setTimeout(() => leaving.remove(), 950);

            rows.forEach((row, i) =>
                row.style.setProperty("--y", `${slotY(i + 1)}px`),
            );

            const entering = template.cloneNode(true);
            fill(entering, vaultDocs[next % vaultDocs.length]);
            next += 1;
            entering.style.setProperty(
                "--y",
                `${FLOW_ENTER_Y - FLOW_ROW_H / 2}px`,
            );
            entering.style.opacity = "0";
            list.appendChild(entering);
            entering.getBoundingClientRect();
            entering.style.setProperty("--y", `${slotY(0)}px`);
            entering.style.opacity = "1";
            rows.unshift(entering);

            docs += 1;
            more += 1;
            // Roughly 50MB a document, so the vault size stays believable on a tab
            // someone leaves open.
            size = Math.round((size + 0.05) * 100) / 100;
            docsEl.textContent = docs.toLocaleString("en-US");
            sizeEl.textContent = size.toFixed(1);
            moreEl.textContent = `+${more.toLocaleString("en-US")}`;

            const tile = nearTiles[Math.floor(Math.random() * nearTiles.length)];
            if (tile) {
                tile.classList.add("is-filed");
                setTimeout(() => tile.classList.remove("is-filed"), 1400);
            }
        };

        // Only run while the hero is on screen; a hidden conveyor helps no one.
        if (!reducedMotion) {
            let timer = null;
            const flowObs = new IntersectionObserver(
                (entries) => {
                    const visible = entries.some(
                        (entry) => entry.isIntersecting,
                    );
                    if (visible && timer === null) {
                        timer = setInterval(advance, 1900);
                    } else if (!visible && timer !== null) {
                        clearInterval(timer);
                        timer = null;
                    }
                },
                { threshold: 0.2 },
            );
            flowObs.observe(flow);
        }
    }

    // Cadence — draw timeline + activate markers + slide in cards
    const cadenceSection = document.getElementById("cadence-inner");

    // Background video is decorative — hold it still for reduced-motion users.
    const bgVideo = document.querySelector(".bg-video");
    if (bgVideo && reducedMotion) {
        bgVideo.removeAttribute("autoplay");
        bgVideo.pause();
    }
    const runCadence = () => {
        if (reducedMotion) {
            document
                .querySelectorAll("[data-marker]")
                .forEach((m) => m.classList.add("is-active"));
            document
                .querySelectorAll("[data-cadence-card]")
                .forEach((c) => c.classList.add("is-visible"));
            return;
        }
        const line = document.getElementById("cadence-line");
        if (line && line.getTotalLength) {
            const len = line.getTotalLength();
            line.style.transition = "none";
            line.style.strokeDasharray = String(len);
            line.style.strokeDashoffset = String(len);
            line.getBoundingClientRect();
            line.style.transition =
                "stroke-dashoffset 1100ms cubic-bezier(0.4,0,0.2,1)";
            line.style.strokeDashoffset = "0";
        }
        const markers = document.querySelectorAll("[data-marker]");
        const cards = document.querySelectorAll("[data-cadence-card]");
        const delays = [420, 820, 1220];
        markers.forEach((marker, i) => {
            setTimeout(() => {
                marker.classList.add("is-active");
                const card = cards[i];
                if (card) card.classList.add("is-visible");
            }, delays[i]);
        });
    };
    if (cadenceSection) {
        const cadObs = new IntersectionObserver(
            (entries) => {
                entries.forEach((entry) => {
                    if (entry.isIntersecting) {
                        runCadence();
                        cadObs.disconnect();
                    }
                });
            },
            { threshold: 0.3 },
        );
        cadObs.observe(cadenceSection);
    }

    // Try it — client-side demo draft (no backend call)
    const input = document.getElementById("tryit-input");
    const draftBtn = document.getElementById("tryit-draft");
    const errorEl = document.getElementById("tryit-error");
    const loadingEl = document.getElementById("tryit-loading");
    const resultEl = document.getElementById("tryit-result");
    const placeholderEl = document.getElementById("tryit-placeholder");

    const showState = (state) => {
        loadingEl.hidden = state !== "loading";
        resultEl.hidden = state !== "result";
        placeholderEl.hidden = state !== "placeholder";
    };
    showState("placeholder");

    const draft = () => {
        const value = (input.value || "").trim();
        errorEl.hidden = true;
        if (!value) {
            errorEl.hidden = false;
            errorEl.textContent = "Tell us what you need to say first.";
            return;
        }
        showState("loading");
        const match = presets.find((p) => p.input === value);
        setTimeout(() => {
            resultEl.textContent = match ? match.output : defaultOutput;
            showState("result");
        }, 500);
    };

    if (draftBtn) draftBtn.addEventListener("click", draft);

    document.querySelectorAll(".tryit-preset").forEach((btn) => {
        btn.addEventListener("click", () => {
            const i = Number(btn.getAttribute("data-preset-index"));
            const preset = presets[i];
            if (!preset) return;
            input.value = preset.input;
            draft();
        });
    });
</script>
