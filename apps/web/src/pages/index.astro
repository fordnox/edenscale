---
import Layout from "../layouts/Layout.astro";
import GrainField from "../components/GrainField.astro";
import LogoIcon from "@edenscale/brand/components/LogoIcon.astro";
import {
    MARK_PATH,
    MARK_TRANSFORM,
} from "@edenscale/brand/components/markPath.ts";

/* ---------- Hero flow diagram ----------
   A fixed 700x420 SVG stage: documents queue on the left, route through the
   NewTaven mark, and accumulate in the fund's vault. Everything is authored in
   stage units so one viewBox scales the whole diagram with the hero card. */
const FLOW_ROWS = [72, 152, 232]; // vertical centre of each visible row
const FLOW_PILL_Y = 316; // vertical centre of the "+N more" pill
const FLOW_ROW_H = 48;
const FLOW_ENTER_Y = -8; // where a new row starts, above the first slot
const FLOW_EXIT_Y = 284; // where the oldest row fades into the pill
const NODE = { x: 352, y: 195, size: 40 };
const LINE_START = 214;
const CARD = { x: 392, y: 134, w: 232, h: 122 };

/* Each source routes right, turns once, and joins a tight bundle at the mark.
   Outer rows turn later so the four verticals never share an x. */
const BENDS = [300, 282, 288, 306];
const BUNDLE = [-4.5, -1.5, 1.5, 4.5];

const elbow = (x0: number, y0: number, xb: number, y1: number, x2: number) => {
    if (Math.abs(y1 - y0) < 0.5) return `M ${x0} ${y0} H ${x2}`;
    const down = y1 > y0;
    const s = down ? 1 : -1;
    const r = Math.min(
        14,
        Math.abs(y1 - y0) / 2,
        Math.abs(xb - x0),
        Math.abs(x2 - xb),
    );
    return [
        `M ${x0} ${y0}`,
        `H ${xb - r}`,
        `A ${r} ${r} 0 0 ${down ? 1 : 0} ${xb} ${y0 + s * r}`,
        `V ${y1 - s * r}`,
        `A ${r} ${r} 0 0 ${down ? 0 : 1} ${xb + r} ${y1}`,
        `H ${x2}`,
    ].join(" ");
};

const flowLines = [...FLOW_ROWS, FLOW_PILL_Y].map((y, i) =>
    elbow(
        LINE_START,
        y,
        BENDS[i],
        NODE.y + BUNDLE[i],
        NODE.x - NODE.size / 2 - 2,
    ),
);

/* What's already in the vault: a field of filed pages behind the card, densest
   against it and dissolving into the panel edge. Jitter and brightness come
   from a hash rather than Math.random so the build output is stable. */
const TILE = { w: 13, h: 17 };
const FIELD = { cols: 17, rows: 19, gapX: 21, gapY: 25, x0: 380, y0: -14 };
const FOCAL = { x: 624, y: 195 };
const FIELD_REACH = 260; // tiles fade to nothing well inside the grid extents
const hash = (a: number, b: number) => {
    const n = Math.sin(a * 127.1 + b * 311.7) * 43758.5453;
    return n - Math.floor(n);
};

const vaultField: { x: number; y: number; o: number; near: boolean }[] = [];
for (let j = 0; j < FIELD.rows; j++) {
    for (let i = 0; i < FIELD.cols; i++) {
        const r1 = hash(i, j);
        const r2 = hash(j + 7, i + 3);
        const x = FIELD.x0 + i * FIELD.gapX + (r1 - 0.5) * 5;
        const y = FIELD.y0 + j * FIELD.gapY + (r2 - 0.5) * 5;
        // Tiles wholly behind the opaque card would never be seen.
        if (
            x >= CARD.x &&
            x + TILE.w <= CARD.x + CARD.w &&
            y >= CARD.y &&
            y + TILE.h <= CARD.y + CARD.h
        ) {
            continue;
        }
        const d = Math.hypot(x + TILE.w / 2 - FOCAL.x, y + TILE.h / 2 - FOCAL.y);
        const t = Math.max(0, 1 - d / FIELD_REACH);
        let o = Math.pow(t, 1.7) * 0.42 * (0.3 + 0.7 * r1);
        if (r2 > 0.94) o = Math.min(0.6, o + 0.3 * t); // a few read as fully filed
        if (o < 0.015) continue; // below this it is not worth the markup
        vaultField.push({
            x: Math.round(x * 10) / 10,
            y: Math.round(y * 10) / 10,
            o: Math.round(o * 1000) / 1000,
            near: t > 0.55,
        });
    }
}

/* The queue cycles through these; the register never runs out of paperwork. */
const vaultDocs = [
