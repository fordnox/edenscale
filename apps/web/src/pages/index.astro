        class="bg-video"
        src="https://d8j0ntlcm91z4.cloudfront.net/user_38xzZboKViGWJOttwIXH07lWA1P/hf_20260329_050842_be71947f-f16e-4a14-810c-06e83d23ddb5.mp4"
        autoplay
        muted
        loop
        playsinline
        aria-hidden="true"></video>

    <!-- Navbar + hero fill the first viewport -->
    <div class="screen" id="top">
        <nav class="navbar" aria-label="Primary">
            <div class="navbar-row">
                <a href="#top" class="brand">
                    <LogoIcon size={28} />
                    <span>NewTaven</span>
                </a>
                <div class="nav-links">
                    <a href="#platform">Platform</a>
                    <a href="#how">How it works</a>
                    <a href="#use-cases">Use cases</a>
                    <a href="#pricing">Pricing</a>
                </div>
                <a href="/manager" class="pill pill--nav">Try Now</a>
            </div>
        </nav>

        <section class="hero">
            <div class="hero-card nv-dark">
                <GrainField kind="dark" pattern="dots" />
                <div class="hero-overlay">
                    <div class="hero-copy">
                        <h1 class="hero-title">
                            Fund Operations,<br />Automated
                        </h1>
                        <p class="hero-sub">
                            The LP register, the capital calls, the
                            distributions, and the follow-ups in between — run
                            in one place instead of across your inbox and a
                            spreadsheet.
                        </p>
                        <a href="/manager" class="pill pill--invert pill--hero">
                            <span>Try Now</span>
                            <span
                                class="pill-arrow pill-arrow--dark"
                                aria-hidden="true"
                            >
                                <svg
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="2"
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    ><path d="M5 12h14M12 5l7 7-7 7"
                                    ></path></svg
                                >
                            </span>
                        </a>
                    </div>

                    <div class="hero-flow-col" aria-hidden="true">
                        <svg class="hero-flow" viewBox="0 0 700 420" data-flow>
                            <!-- Everything already filed -->
                            <defs>
                                <path
                                    id="vault-tile"
                                    d="M3 0 H9 L13 4 V15 A2 2 0 0 1 11 17 H3 A2 2 0 0 1 1 15 V2 A2 2 0 0 1 3 0 Z"
                                ></path>
                            </defs>
                            <g class="flow-field">
                                {
                                    vaultField.map((t) => (
                                        <use
                                            href="#vault-tile"
                                            class="flow-tile"
                                            x={t.x}
                                            y={t.y}
                                            style={`--o: ${t.o}`}
                                            data-near={t.near ? "" : null}
                                        />
                                    ))
                                }
                            </g>

                            <!-- Connectors: queue -> mark -> vault -->
                            {
                                flowLines.map((d) => (
                                    <path d={d} class="flow-line" />
                                ))
                            }
                            {
                                [-4, 0, 4].map((dy) => (
                                    <path
                                        d={`M ${NODE.x + NODE.size / 2} ${NODE.y + dy} H ${CARD.x}`}
                                        class="flow-line"
                                    />
                                ))
                            }

                            <!-- The NewTaven mark, where everything converges -->
                            <g class="flow-node">
                                <rect
                                    x={NODE.x - NODE.size / 2}
                                    y={NODE.y - NODE.size / 2}
                                    width={NODE.size}
                                    height={NODE.size}
                                    rx="12"></rect>
                                <g
                                    transform={`translate(${NODE.x - 11} ${NODE.y - 11}) scale(0.34375)`}
                                >
                                    <g transform={MARK_TRANSFORM}>
                                        <path
                                            fill-rule="evenodd"
                                            d={MARK_PATH}
                                            class="flow-node-mark"></path>
                                    </g>
                                </g>
                            </g>

                            <!-- The vault -->
                            <g class="flow-card">
                                <rect
                                    x={CARD.x}
                                    y={CARD.y}
                                    width={CARD.w}
                                    height={CARD.h}
                                    rx="10"></rect>
                                <text
                                    x={CARD.x + 24}
                                    y={CARD.y + 32}
                                    class="flow-card-title"
                                    >AI & Human Review</text
                                >
                                <text
                                    x={CARD.x + 24}
                                    y={CARD.y + 62}
                                    class="flow-card-value"
                                    ><tspan data-vault-docs>1,284</tspan> docs · <tspan
                                        data-vault-size>6.1</tspan
                                    > GB</text
                                >
                                <line
                                    x1={CARD.x + 16}
                                    y1={CARD.y + 80}
                                    x2={CARD.x + CARD.w - 16}
                                    y2={CARD.y + 80}
                                    class="flow-card-rule"></line>
