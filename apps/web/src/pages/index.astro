<script define:vars={{ presets, defaultOutput }}>
  // Scroll reveals — opacity 0 -> 1 + translateY, once
  const revealObs = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add("is-visible");
          revealObs.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.15 }
  );
  document.querySelectorAll("[data-reveal]").forEach((el) => revealObs.observe(el));

  // Cadence — draw timeline + activate markers + slide in cards
  const cadenceSection = document.getElementById("cadence-inner");
  const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
  const runCadence = () => {
    if (reducedMotion) {
      document.querySelectorAll("[data-marker]").forEach((m) => m.classList.add("is-active"));
      document.querySelectorAll("[data-cadence-card]").forEach((c) => c.classList.add("is-visible"));
      return;
    }
    const line = document.getElementById("cadence-line");
    if (line && line.getTotalLength) {
      const len = line.getTotalLength();
      line.style.transition = "none";
      line.style.strokeDasharray = String(len);
      line.style.strokeDashoffset = String(len);
      line.getBoundingClientRect();
      line.style.transition = "stroke-dashoffset 1100ms cubic-bezier(0.4,0,0.2,1)";
      line.style.strokeDashoffset = "0";
    }
    const markers = document.querySelectorAll("[data-marker]");
    const cards = document.querySelectorAll("[data-cadence-card]");
    const delays = [420, 820, 1220];
    markers.forEach((marker, i) => {
      setTimeout(() => {
        marker.classList.add("is-active");
        const card = cards[i];
        if (card) card.classList.add("is-visible");
      }, delays[i]);
    });
  };
  if (cadenceSection) {
    const cadObs = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            runCadence();
            cadObs.disconnect();
          }
        });
      },
      { threshold: 0.3 }
    );
    cadObs.observe(cadenceSection);
  }

  // Try it — client-side demo draft (no backend call)
  const input = document.getElementById("tryit-input");
  const draftBtn = document.getElementById("tryit-draft");
  const errorEl = document.getElementById("tryit-error");
  const loadingEl = document.getElementById("tryit-loading");
  const resultEl = document.getElementById("tryit-result");
  const placeholderEl = document.getElementById("tryit-placeholder");

  const showState = (state) => {
    loadingEl.hidden = state !== "loading";
    resultEl.hidden = state !== "result";
    placeholderEl.hidden = state !== "placeholder";
  };
  showState("placeholder");

  const draft = () => {
    const value = (input.value || "").trim();
    errorEl.hidden = true;
    if (!value) {
      errorEl.hidden = false;
      errorEl.textContent = "Tell us what you need to say first.";
      return;
    }
    showState("loading");
    const match = presets.find((p) => p.input === value);
    setTimeout(() => {
      resultEl.textContent = match ? match.output : defaultOutput;
      showState("result");
    }, 500);
  };

  if (draftBtn) draftBtn.addEventListener("click", draft);

  document.querySelectorAll(".tryit-preset").forEach((btn) => {
    btn.addEventListener("click", () => {
      const i = Number(btn.getAttribute("data-preset-index"));
      const preset = presets[i];
      if (!preset) return;
      input.value = preset.input;
      draft();
    });
  });
</script>
