---
import Layout from "../layouts/Layout.astro";
import GrainField from "../components/GrainField.astro";
import LogoIcon from "@edenscale/brand/components/LogoIcon.astro";

/* Faux-logotype styling per brand keeps the marquee feeling like a row of
   real marks without shipping image assets. */
const integrations = [
  {
    name: "Stripe",
    style: "font-family: Georgia, 'Times New Roman', serif; font-weight: 700; letter-spacing: -0.02em; font-size: 15px;",
  },
  {
    name: "DocuSign",
    style: "font-family: Arial, sans-serif; font-weight: 900; letter-spacing: 0.08em; font-size: 13px; text-transform: uppercase;",
  },
  {
    name: "Plaid",
    style: "font-family: 'Trebuchet MS', sans-serif; font-weight: 600; letter-spacing: 0.01em; font-size: 15px; font-style: italic;",
  },
  {
    name: "Carta",
    style: "font-family: 'Courier New', monospace; font-weight: 700; letter-spacing: 0.12em; font-size: 13px; text-transform: uppercase;",
  },
  {
    name: "Xero",
    style: "font-family: Palatino, 'Book Antiqua', serif; font-weight: 400; letter-spacing: -0.01em; font-size: 16px;",
  },
  {
    name: "Salesforce",
    style: "font-family: Impact, 'Arial Narrow', sans-serif; font-weight: 400; letter-spacing: 0.04em; font-size: 14px;",
  },
  {
    name: "HubSpot",
    style: "font-family: Verdana, sans-serif; font-weight: 700; letter-spacing: -0.03em; font-size: 13px;",
  },
];

const backers = [
  {
    name: "Meridian Family Office",
    style: "font-family: 'Times New Roman', serif; font-weight: 400; letter-spacing: 0.02em; font-size: 14px;",
  },
  {
    name: "Kessler Capital",
    style: "font-family: 'Arial Black', Arial, sans-serif; font-weight: 900; letter-spacing: 0.08em; font-size: 16px; text-transform: uppercase;",
  },
  {
    name: "Novak & Sons",
    style: "font-family: Impact, 'Arial Narrow', sans-serif; font-weight: 700; letter-spacing: 0.05em; font-size: 18px;",
  },
  {
    name: "Alderman Endowment",
    style: "font-family: Georgia, serif; font-weight: 600; letter-spacing: -0.02em; font-size: 17px;",
  },
  {
    name: "Beacon Family Office",
    style: "font-family: Helvetica, Arial, sans-serif; font-weight: 700; letter-spacing: -0.01em; font-size: 15px;",
  },
  {
    name: "Stillwater Group",
    style: "font-family: Verdana, sans-serif; font-weight: 700; letter-spacing: 0.06em; font-size: 14px; text-transform: uppercase;",
  },
  {
    name: "Harlow Rand",
    style: "font-family: 'Courier New', monospace; font-weight: 700; letter-spacing: 0.18em; font-size: 14px;",
  },
  {
    name: "Corminster Trust",
    style: "font-family: Palatino, 'Book Antiqua', serif; font-weight: 500; letter-spacing: 0.03em; font-size: 15px;",
  },
];

const problems = [
  {
    n: "01",
    title: "Capital calls live in your inbox.",
    body: "Amounts, wire dates, and confirmations scattered across threads. No single view of who has funded and who hasn't.",
  },
  {
    n: "02",
    title: "LP records drift out of date.",
    body: "A commitment changes, a contact leaves, an entity is restructured — and the spreadsheet quietly stops matching reality.",
  },
  {
    n: "03",
    title: "Follow-ups depend on remembering.",
    body: "The polite second nudge is the one that gets the wire in. It is also the first thing to fall off a busy week.",
  },
];

const steps = [
  {
    n: "Step 01",
    title: "Bring your LPs in",
    body: "Import commitments, contacts, and entities. NewTaven becomes the register of record for the whole fund.",
  },
  {
    n: "Step 02",
    title: "Issue a call",
    body: "Draft a capital call once. Each LP receives their exact figure, wire details, and due date — no mail merge.",
  },
  {
    n: "Step 03",
    title: "Let the cadence run",
    body: "Wires reconcile against the register. Anyone outstanding gets a measured follow-up on schedule — in your voice.",
  },
];

const cadenceCards = [
  {
    label: "Draft · T+72h",
    tone: "Gentle",
    subject: "A quick note on the Fund II call",
    body: "The Fund II call is at 68% funded. A reminder that your portion — $900,000 — is due by the 30th. Wire details are unchanged, and attached again for convenience.",
  },
  {
    label: "Draft · T+7d",
    tone: "Warm",
    subject: "Following up on the Fund II call",
    body: "One week out. We are holding your allocation. If the timing is tight on your end, reply here and we will work with your team on the date.",
  },
  {
    label: "Draft · T+14d",
    tone: "Direct",
    subject: "Final reminder — Fund II",
    body: "The call closes Friday. Please confirm your wire, or let us know if anything has changed on your end. We would rather adjust than assume.",
  },
];

const features = [
  {
    title: "LP register",
    body: "A single record of every commitment, contact, and entity — always current, always exportable.",
    icon: "M3 4h18v16H3zM3 9.5h18M3 15h18M9 4v16",
  },
  {
    title: "Capital calls & distributions",
    body: "Issue a call once; each LP gets their exact figure and wire instructions. Distributions run the same way, in reverse.",
    icon: "M12 3v10M8 9l4 4 4-4M4 15v3a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-3",
  },
  {
    title: "Automated cadence",
    body: "Measured follow-ups on outstanding wires — 72h, 7d, 14d — sent in your fund's voice, only until the wire clears.",
    icon: "M19 13a7 7 0 1 1-7-7M12 10v3l2 1.5M9 2h6",
  },
  {
    title: "Investor portal",
    body: "Each LP sees their commitments, calls, distributions, and documents — without another login you have to support.",
    icon: "M4 10h16v11H4zM8 10V7a4 4 0 0 1 8 0v3",
  },
  {
    title: "Quarterly letters",
    body: "Compose the letter once; NewTaven personalizes and delivers it on the fifteenth, with read receipts by LP.",
    icon: "M3 5h18v14H3zM3 6l9 7 9-7",
  },
  {
    title: "Wire reconciliation",
    body: "Incoming wires match against the register automatically. What clears is marked funded; what doesn't enters the cadence.",
    icon: "M3 12a9 9 0 1 1 9 9M3 12v5h5M9 12l2 2 4-4",
  },
];

const presets = [
  {
    label: "Delay in a distribution",
    input: "There will be a short delay in the Q2 distribution while we finalize a portfolio company's audit.",
    output:
      "Subject: A short delay on the Q2 distribution\n\nThe Q2 distribution will be a few weeks later than planned while we finalize a portfolio company's audit. The amount is unchanged. We will confirm the new date as soon as the audit closes.\n\nWe appreciate your patience.",
  },
  {
    label: "New portfolio company",
    input: "We've completed a new investment — a control position in a founder-led logistics business — and want to introduce it.",
    output:
      "Subject: A new addition to the portfolio\n\nWe have completed a control investment in a founder-led logistics business. The founder remains in an operating role, and we are supporting the next phase of growth alongside the existing team.\n\nMore detail will follow in the next quarterly letter.",
  },
  {
    label: "Quarterly update is live",
    input: "Our Q2 quarterly letter is now live in the investor portal.",
    output:
      "Subject: Q2 letter is now available\n\nThe Q2 quarterly letter is live in the investor portal, along with updated capital account statements. Please let us know if anything is unclear.\n\nAs always, we are glad to schedule a call to walk through it.",
  },
];

const defaultOutput =
  "Subject: A note for our limited partners\n\nThank you for the context. Here is a short, plain draft based on what you described — ready to review, edit, and send from NewTaven.\n\nWe will follow up directly if anything changes.";
---

<Layout>
  <!-- Fixed background video — shows in the gutters around the content -->
  <video
    class="bg-video"
    src="https://d8j0ntlcm91z4.cloudfront.net/user_38xzZboKViGWJOttwIXH07lWA1P/hf_20260329_050842_be71947f-f16e-4a14-810c-06e83d23ddb5.mp4"
    autoplay
    muted
    loop
    playsinline
    aria-hidden="true"></video>

  <!-- Navbar + hero fill the first viewport -->
  <div class="screen" id="top">
    <nav class="navbar" aria-label="Primary">
      <div class="navbar-row">
        <a href="#top" class="brand">
          <LogoIcon size={28} />
          <span>NewTaven</span>
        </a>
        <div class="nav-links">
          <a href="#platform">Platform</a>
          <a href="#how">How it works</a>
          <a href="#use-cases">Use cases</a>
          <a href="#pricing">Pricing</a>
        </div>
        <a href="/manager" class="pill pill--nav">Try Now</a>
      </div>
    </nav>

    <section class="hero">
      <div class="hero-card">
        <GrainField kind="card" pattern="dots" />
        <div class="hero-overlay">
          <h1 class="hero-title">Fund Operations,<br />Automated</h1>
          <p class="hero-sub">
            An end-to-end software platform built to streamline the entire lifecycle of your
            investment fund, from LP onboarding to seamless capital distributions.
          </p>
          <a href="/manager" class="pill pill--hero">
            <span>Try Now</span>
            <span class="pill-arrow" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"></path></svg>
            </span>
          </a>

          <div class="hero-marquee">
            <div class="marquee-track marquee-track--hero">
              {[0, 1].map((dup) => (
                <div class="marquee-group" aria-hidden={dup === 1}>
                  {integrations.map((b) => (
                    <span class="marquee-item" style={b.style}>{b.name}</span>
                  ))}
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>
  </div>

  <div class="sheet">
  <main>
    <!-- The problem -->
    <section id="problem" class="sect">
      <div class="container">
        <div class="sect-head" data-reveal>
          <span class="eyebrow">The problem</span>
          <h2 class="sect-title">Managers run funds on<br />memory and spreadsheets.</h2>
        </div>
        <div class="cards-3" data-reveal>
          {problems.map((p) => (
            <article class="card">
              <span class="card-index">{p.n}</span>
              <div>
                <h3 class="card-title">{p.title}</h3>
                <p class="card-body">{p.body}</p>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- Meet NewTaven -->
    <section id="platform" class="sect">
      <div class="container">
        <div class="info-head" data-reveal>
          <div>
            <h2 class="sect-title">Meet NewTaven.</h2>
            <a href="#features" class="pill pill--base">
              <span>Explore features</span>
              <span class="pill-arrow" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"></path></svg>
              </span>
            </a>
          </div>
          <p class="info-lede">
            NewTaven is a comprehensive fund operating system that fully automates your
            back-office, allowing GPs to focus purely on making investments and driving returns.
          </p>
        </div>

        <div class="info-cards" data-reveal>
          <article class="info-card info-card--visual">
            <h3>Capital Calls, Simplified</h3>
            <p>
              Automate notices, accurately track incoming commitments, and automatically reconcile
              accounts with zero manual data entry.
            </p>
          </article>
          <article class="info-card info-card--green nv-dark">
            <h3>Elevated LP<br />Experience.</h3>
            <p>
              Provide your limited partners with a dedicated, white-labeled portal for real-time
              reporting, tax documents, and performance metrics.
            </p>
          </article>
          <article class="info-card info-card--green nv-dark">
            <h3>End-to-End<br />Compliance</h3>
            <p>
              Built-in KYC/AML workflows and automated regulatory reporting operate quietly in the
              background to keep your fund secure.
            </p>
          </article>
        </div>
      </div>
    </section>

    <!-- Trusted by -->
    <section id="investors" class="backers">
      <div class="container backers-grid">
        <p class="backers-note">Trusted by top-tier GPs<br />and forward-thinking firms.</p>
        <div class="backers-marquee">
          <div class="marquee-track marquee-track--backers">
            {[0, 1].map((dup) => (
              <div class="marquee-group" aria-hidden={dup === 1}>
                {backers.map((b) => (
                  <span class="marquee-item marquee-item--backer" style={b.style}>{b.name}</span>
                ))}
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- How it works -->
    <section id="how" class="sect">
      <div class="container">
        <div class="sect-head" data-reveal>
          <span class="eyebrow">How it works</span>
          <h2 class="sect-title">Three steps, then it runs itself.</h2>
          <p class="sect-sub">
            Bring your fund in once. From there, NewTaven handles the mechanics you would otherwise
            do by hand.
          </p>
        </div>
        <div class="steps" data-reveal>
          {steps.map((s) => (
            <div class="step">
              <span class="step-index">{s.n}</span>
              <h3 class="step-title">{s.title}</h3>
              <p class="card-body">{s.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- The cadence -->
    <section id="cadence" class="sect">
      <div class="container">
        <div class="cadence-card nv-dark">
          <GrainField kind="dark" />
          <div class="cadence-inner" id="cadence-inner">
            <span class="eyebrow eyebrow--light">The cadence</span>
            <h2 class="sect-title sect-title--light">The follow-ups you'd<br />never get around to.</h2>
            <p class="sect-sub sect-sub--light">
              When a wire is still outstanding, NewTaven sends a measured reminder — at 72 hours,
              7 days, and 14 days. Considerate, never pushy. You approve the voice once.
            </p>

            <svg viewBox="0 0 1120 96" width="100%" class="cadence-timeline" aria-hidden="true">
              <line x1="8" y1="48" x2="1112" y2="48" stroke="rgba(255,255,255,0.16)" stroke-width="1"></line>
              <path id="cadence-line" d="M8 48 H 1112" fill="none" stroke="#FFFFFF" stroke-width="2"></path>
              <g>
                <circle data-marker cx="200" cy="48" r="7" fill="#FFFFFF" class="cadence-marker"></circle>
                <circle cx="200" cy="48" r="7" fill="none" stroke="rgba(255,255,255,0.3)" stroke-width="1"></circle>
              </g>
              <g>
                <circle data-marker cx="560" cy="48" r="7" fill="#FFFFFF" class="cadence-marker"></circle>
                <circle cx="560" cy="48" r="7" fill="none" stroke="rgba(255,255,255,0.3)" stroke-width="1"></circle>
              </g>
              <g>
                <circle data-marker cx="920" cy="48" r="7" fill="#FFFFFF" class="cadence-marker"></circle>
                <circle cx="920" cy="48" r="7" fill="none" stroke="rgba(255,255,255,0.3)" stroke-width="1"></circle>
              </g>
              <text x="200" y="82" text-anchor="middle" fill="rgba(255,255,255,0.62)" class="cadence-tag">T+72h</text>
              <text x="560" y="82" text-anchor="middle" fill="rgba(255,255,255,0.62)" class="cadence-tag">T+7d</text>
              <text x="920" y="82" text-anchor="middle" fill="rgba(255,255,255,0.62)" class="cadence-tag">T+14d</text>
            </svg>

            <div class="cadence-mails">
              {cadenceCards.map((c) => (
                <div data-cadence-card class="cadence-mail">
                  <div class="cadence-mail-head">
                    <span class="cadence-mail-label">{c.label}</span>
                    <span class="cadence-mail-tone">{c.tone}</span>
                  </div>
                  <div class="cadence-mail-subject">{c.subject}</div>
                  <p class="cadence-mail-body">{c.body}</p>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Features -->
    <section id="features" class="sect">
      <div class="container">
        <div class="sect-head" data-reveal>
          <span class="eyebrow">Features</span>
          <h2 class="sect-title">Everything the fund needs.<br />Nothing it doesn't.</h2>
        </div>
        <div class="features-grid" data-reveal>
          {features.map((f) => (
            <article class="card card--feature">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#16281F" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d={f.icon}></path>
              </svg>
              <div>
                <h3 class="card-title">{f.title}</h3>
                <p class="card-body">{f.body}</p>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- Use cases -->
    <section id="use-cases" class="sect">
      <div class="container usecases-grid">
        <div class="usecases-left">
          <span class="eyebrow">NewTaven in Practice</span>
          <h2>Built for scale</h2>
          <p>
            NewTaven powers a wide range of operational modes for venture capital, private equity,
            and hedge funds wanting secure, automated fund administration.
          </p>
        </div>
        <div class="usecase-card nv-dark">
          <GrainField kind="dark" />
          <div class="usecase-overlay">
            <h3>Automated Distributions</h3>
            <p>
              Streamline the payout process. Calculate complex waterfall distributions instantly
              and disburse capital to your LPs with complete accuracy and transparent audit trails.
            </p>
            <a href="mailto:hello@newtaven.com" class="usecase-link">
              <span class="usecase-link-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"></path></svg>
              </span>
              View workflows
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Try it -->
    <section id="try" class="sect">
      <div class="container">
        <div class="tryit-frame" data-reveal>
          <div class="tryit-left">
            <span class="eyebrow">Try it</span>
            <h2 class="tryit-title">Draft an LP note in NewTaven's voice.</h2>
            <p class="tryit-body">
              Describe the situation. NewTaven writes a short, plain email you could send to your
              limited partners — no puffery, no exclamation marks.
            </p>
            <div class="tryit-form">
              <label class="tryit-label" for="tryit-input">What do you need to say?</label>
              <textarea
                id="tryit-input"
                class="tryit-textarea"
                rows="4"
                placeholder="e.g. Fund II is closing next month and we're at 82% of target."></textarea>
              <div class="tryit-presets">
                {presets.map((p, i) => (
                  <button type="button" class="tryit-preset" data-preset-index={i}>{p.label}</button>
                ))}
              </div>
              <button type="button" id="tryit-draft" class="pill pill--submit">Draft the note</button>
              <span id="tryit-error" class="tryit-error" hidden></span>
            </div>
          </div>
          <div class="tryit-preview">
            <div class="tryit-preview-head">
              <span class="tryit-preview-label">Draft preview</span>
              <span class="tryit-preview-to">to: limited partners</span>
            </div>
            <div id="tryit-loading" class="tryit-loading" hidden>
              <span class="tryit-dot"></span>Drafting a note…
            </div>
            <div id="tryit-result" class="tryit-result" hidden></div>
            <div id="tryit-placeholder" class="tryit-placeholder">
              Your drafted note will appear here — ready to review, edit, and send from NewTaven.
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Pricing -->
    <section id="pricing" class="sect">
      <div class="container pricing-grid" data-reveal>
        <div>
          <span class="eyebrow">Pricing</span>
          <h2 class="sect-title">Pricing is<br />a conversation.</h2>
        </div>
        <div>
          <p class="pricing-body">
            Every fund is a different size, at a different stage, with a different LP base. We
            would rather understand yours than post a number that fits no one. A short call, a
            fair quote, no obligation.
          </p>
          <div class="pricing-actions">
            <a href="mailto:hello@newtaven.com" class="pill pill--base">
              <span>Contact us for pricing</span>
              <span class="pill-arrow" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"></path></svg>
              </span>
            </a>
            <a href="mailto:hello@newtaven.com" class="pricing-mail">hello@newtaven.com</a>
          </div>
        </div>
      </div>
    </section>

    <!-- Closing CTA -->
    <section class="sect">
      <div class="container">
        <div class="cta-card nv-dark">
          <GrainField kind="dark" />
          <div class="cta-inner">
            <h2>Give your fund the back office it never had time to build.</h2>
            <a href="/manager" class="pill pill--invert">
              <span>Try Now</span>
              <span class="pill-arrow pill-arrow--dark" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"></path></svg>
              </span>
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>

  <footer class="footer">
    <div class="container footer-row">
      <a href="#top" class="brand brand--footer">
        <LogoIcon size={20} />
        <span>NewTaven</span>
      </a>
      <a href="mailto:hello@newtaven.com" class="footer-mail">hello@newtaven.com</a>
      <span class="footer-copy">© 2026 NewTaven — Fund administration for small managers</span>
    </div>
  </footer>
  </div>
</Layout>

<style>
  /* ---------- Shared ---------- */
  .container {
    max-width: 88rem;
    margin: 0 auto;
  }

  /* Fixed page-background video: 115% width/height, centered horizontally,
     anchored to the top with a top focal point. It stays put while the
     content scrolls over it; the sheet below limits it to the outer frame. */
  .bg-video {
    position: fixed;
    top: 0;
    left: 50%;
    width: 115%;
    height: 115%;
    transform: translateX(-50%);
    object-fit: cover;
    object-position: top;
    pointer-events: none;
  }

  /* Everything below the hero rides on a light sheet, leaving gutters where
     the fixed video shows through while scrolling. */
  .sheet {
    position: relative;
    background: #f5f5f5;
    border-radius: 24px;
    margin: 0 24px 24px;
  }

  .sect {
    padding: 72px 24px;
  }
  .sect-head {
    margin-bottom: 56px;
    max-width: 46rem;
  }
  .sect-title {
    margin: 0;
    color: #000;
    font-size: clamp(36px, 4vw, 48px);
    font-weight: 500;
    line-height: 1.12;
    letter-spacing: -0.03em;
  }
  .sect-title--light {
    color: #fff;
  }
  .sect-sub {
    margin: 20px 0 0;
    color: rgba(0, 0, 0, 0.6);
    font-size: clamp(16px, 1.3vw, 18px);
    line-height: 1.6;
    max-width: 36rem;
  }
  .sect-sub--light {
    color: rgba(255, 255, 255, 0.7);
  }
  .eyebrow {
    display: block;
