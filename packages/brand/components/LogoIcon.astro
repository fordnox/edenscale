---
/* NewTaven raven mark — inherits color via currentColor.
   Same geometry as Mark.astro; this variant takes its colour from the
   surrounding text rather than a prop, which is what the site navbars want. */
import { MARK_PATH, MARK_TRANSFORM, MARK_VIEWBOX } from "./markPath.ts";

interface Props {
  size?: number;
}
const { size = 24 } = Astro.props;
---

<svg viewBox={MARK_VIEWBOX} width={size} height={size} fill="currentColor" aria-hidden="true">
  <g transform={MARK_TRANSFORM}>
    <path fill-rule="evenodd" d={MARK_PATH}></path>
  </g>
</svg>
