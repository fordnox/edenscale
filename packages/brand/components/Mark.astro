---
/* NewTaven raven mark. Geometry lives in ./markPath.ts — see the note there. */
import { MARK_PATH, MARK_TRANSFORM, MARK_VIEWBOX } from "./markPath.ts";

interface Props {
  size?: number;
  color?: string;
}
const { size = 20, color = "var(--conifer-700)" } = Astro.props;
---

<svg
  viewBox={MARK_VIEWBOX}
  width={size}
  height={size}
  style={`color: ${color};`}
  aria-hidden="true"
>
  <g transform={MARK_TRANSFORM}>
    <path fill="currentColor" fill-rule="evenodd" d={MARK_PATH}></path>
  </g>
</svg>
