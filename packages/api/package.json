{
  "name": "@edenscale/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "generate-client": "openapi-typescript ../../apps/backend/openapi.json -o ./src/schema.d.ts",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit"
  },
  "exports": {
    ".": "./src/client.ts",
    "./client": "./src/client.ts",
    "./config": "./src/config.ts",
