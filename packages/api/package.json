    "./hooks/useApiQuery": "./src/hooks/useApiQuery.ts",
    "./queryClient": "./src/queryClient.ts",
    "./schema": "./src/schema.d.ts"
  },
  "dependencies": {
    "@edenscale/auth": "workspace:*",
    "@tanstack/react-query": "^5.101.2",
    "openapi-fetch": "^0.17.0",
    "sonner": "^2.0.7"
  },
  "devDependencies": {
    "@edenscale/typescript-config": "workspace:*",
    "@types/react": "^19.2.17",
    "openapi-typescript": "^7.13.0",
    "typescript": "^6.0.3"
