# Kamal secrets — values are fetched from 1Password at deploy time.
# Safe to commit: this file contains references/commands, not secret values.
#
# Requires the 1Password CLI (`op`) to be installed and authenticated:
#   - Locally:  `op signin` (or set OP_SERVICE_ACCOUNT_TOKEN)
#   - In CI:    export OP_SERVICE_ACCOUNT_TOKEN (1Password service account)
#
# Docs: https://kamal-deploy.org/docs/commands/secrets/

# Fetch everything from the "mle-backend" item in the "CI" vault in one call.
SECRETS=$(kamal secrets fetch --adapter 1password --account my.1password.com --from Github/taven)

DEBUG=0
KAMAL_REGISTRY_PASSWORD=$(kamal secrets extract KAMAL_REGISTRY_PASSWORD $SECRETS)
APP_DOMAIN=$(kamal secrets extract APP_DOMAIN $SECRETS)
APP_DATA_PATH=$(kamal secrets extract APP_DATA_PATH $SECRETS)
APP_DATABASE_DSN=$(kamal secrets extract APP_DATABASE_DSN $SECRETS)
CORS_ALLOW_ORIGINS=$(kamal secrets extract CORS_ALLOW_ORIGINS $SECRETS)
HANKO_API_URL=$(kamal secrets extract HANKO_API_URL $SECRETS)
HANKO_AUDIENCE=$(kamal secrets extract HANKO_AUDIENCE $SECRETS)
GENERATE_OPENAPI_DOCS=$(kamal secrets extract GENERATE_OPENAPI_DOCS $SECRETS)
RESEND_API_KEY=$(kamal secrets extract RESEND_API_KEY $SECRETS)
SUPERADMIN_EMAIL=$(kamal secrets extract SUPERADMIN_EMAIL $SECRETS)
STORAGE_BACKEND=$(kamal secrets extract STORAGE_BACKEND $SECRETS)
S3_ENDPOINT_URL=$(kamal secrets extract S3_ENDPOINT_URL $SECRETS)
S3_ACCESS_KEY_ID=$(kamal secrets extract S3_ACCESS_KEY_ID $SECRETS)
S3_SECRET_ACCESS_KEY=$(kamal secrets extract S3_SECRET_ACCESS_KEY $SECRETS)
S3_BUCKET_NAME=$(kamal secrets extract S3_BUCKET_NAME $SECRETS)
S3_PUBLIC_URL=$(kamal secrets extract S3_PUBLIC_URL $SECRETS)
EMAIL_INGEST_TOKEN=$(kamal secrets extract EMAIL_INGEST_TOKEN $SECRETS)
OPENROUTER_API_KEY=$(kamal secrets extract OPENROUTER_API_KEY $SECRETS)
OPENROUTER_MODEL=$(kamal secrets extract OPENROUTER_MODEL $SECRETS)
